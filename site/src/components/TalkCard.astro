---
interface Props {
  talk: {
    title: string
    description: string
    repo: string
    slides_url?: string
    date: string
    tags: string[]
  }
}

const { talk } = Astro.props
const repoUrl = `https://github.com/${talk.repo}`
const dateStr = new Date(talk.date).toLocaleDateString('en-BE', {
  year: 'numeric',
  month: 'short',
})
---

<article class="talk-card">
  <div class="card-body">
    <h2 class="card-title">{talk.title}</h2>
    <p class="card-desc">{talk.description}</p>
    <div class="card-tags">
      {talk.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
  <div class="card-footer">
    <span class="card-date">{dateStr}</span>
    <div class="card-links">
      {talk.slides_url && (
        <a href={talk.slides_url} class="btn btn-primary" target="_blank">
          View Slides ↗
        </a>
      )}
      <a href={repoUrl} class="btn btn-secondary" target="_blank">
        GitHub ↗
      </a>
    </div>
  </div>
</article>

<style>
.talk-card {
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s, transform 0.2s;
  background: white;
}
.talk-card:hover {
  box-shadow: 0 4px 20px rgba(232, 71, 0, 0.15);
  transform: translateY(-2px);
}
.card-body {
  padding: 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.card-title {
  font-family: 'Michroma', sans-serif;
  font-size: 1.1rem;
  color: #343434;
  margin: 0;
  line-height: 1.3;
}
.card-desc {
  color: #555;
  font-size: 0.9rem;
  line-height: 1.5;
  margin: 0;
  flex: 1;
}
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.tag {
  background: #f5f5f5;
  border: 1px solid #e0e0e0;
  color: #555;
  font-size: 0.75rem;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
}
.card-footer {
  padding: 1rem 1.5rem;
  background: #fafafa;
  border-top: 1px solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.card-date {
  color: #7e7e7e;
  font-size: 0.8rem;
}
.card-links {
  display: flex;
  gap: 0.5rem;
}
.btn {
  padding: 0.4rem 0.9rem;
  border-radius: 5px;
  font-size: 0.8rem;
  text-decoration: none;
  font-weight: 500;
  transition: opacity 0.15s;
}
.btn:hover {
  opacity: 0.85;
}
.btn-primary {
  background: #e84700;
  color: white;
}
.btn-secondary {
  background: #343434;
  color: white;
}
</style>
